{
  "name": "chess-coach-vn",
  "private": true,
  "version": "0.9.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:code-size": "node scripts/check-code-size.mjs",
    "test:code-size": "node --test scripts/check-code-size.test.mjs",
    "test:board-hints": "node --test tests/board-hints.test.mjs",
    "test:game-previews": "node --test tests/game-previews.test.mjs",
    "test:training-timeline": "node --test tests/training-timeline.test.mjs",
    "test:game-story": "node --test tests/game-story.test.mjs",
    "test:move-classification": "node --test tests/move-classification.test.mjs",
    "test:player-move-stats": "node --test --test-isolation=none tests/player-move-stats.test.mjs",
    "test:tactics": "node --test --test-isolation=none tests/tactics.test.mjs",
    "test:candidate-lab": "node --test --test-isolation=none tests/candidate-lab.test.mjs",
    "test:pgn": "node --test tests/pgn-fixtures.test.mjs",
    "test:report-card": "node --test tests/report-card.test.mjs",
    "update-openings": "node scripts/update-openings.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource/be-vietnam-pro": "^5.3.0",
    "@tauri-apps/api": "2.11.1",
    "chess.js": "1.4.0",
    "firebase": "^12.16.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-chessboard": "5.10.0",
    "react-dom": "^19.1.1",
    "recharts": "^3.10.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
